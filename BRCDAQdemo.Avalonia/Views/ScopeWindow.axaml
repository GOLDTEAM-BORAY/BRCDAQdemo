<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:BRCDAQdemo.Avalonia.Controls"
        xmlns:converters="clr-namespace:BRCDAQdemo.Avalonia.Converters"
        xmlns:brcsdk="clr-namespace:BRCDAQdemo.Core.Lib;assembly=BRCDAQdemo.Core"
        x:Class="BRCDAQdemo.Avalonia.Views.ScopeWindow"
        x:Name="Root"
        Width="1300"
        Height="690"
        MinWidth="960"
        MinHeight="560"
        Title="{Binding Title}">

  <Window.Resources>
    <converters:SampleRateConverter x:Key="SampleRateConverter" />
    <converters:CurrentConverter x:Key="CurrentConverter" />
    <converters:EnumConverter x:Key="EnumConverter" />
  </Window.Resources>

  <Grid ColumnDefinitions="*,300" Margin="14">
    <Border Grid.Column="0"
            CornerRadius="8"
            ClipToBounds="True"
            Background="{DynamicResource SurfaceCardBrush}"
            BorderBrush="{DynamicResource SurfaceBorderBrush}"
            BorderThickness="1"
            Margin="0,0,14,0">
      <controls:AvaPlot Name="WavePlot" />
    </Border>

    <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Disabled" VerticalScrollBarVisibility="Auto">
      <StackPanel Spacing="12">
        <GroupBox Header="波形">
          <ItemsControl ItemsSource="{Binding ChannelProperties}">
            <ItemsControl.ItemsPanel>
              <ItemsPanelTemplate>
                <WrapPanel />
              </ItemsPanelTemplate>
            </ItemsControl.ItemsPanel>
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <CheckBox Content="{Binding Id, StringFormat=通道{0}}"
                          IsChecked="{Binding ShowSignal}"
                          MinWidth="78"
                          Margin="0,0,6,6" />
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </GroupBox>

        <GroupBox Header="设置">
          <StackPanel Spacing="10" IsEnabled="{Binding !Started}">
            <Grid RowDefinitions="Auto,Auto" RowSpacing="8">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto" SharedSizeGroup="A" />
                <ColumnDefinition Width="*" />
              </Grid.ColumnDefinitions>

              <TextBlock Grid.Row="0" Grid.Column="0" Text="采样率:" VerticalAlignment="Center" Margin="0,0,10,0" />
              <ComboBox Grid.Row="0"
                        Grid.Column="1"
                        ItemsSource="{Binding Device.ModuleInfo.SampleRateOptions}"
                        SelectedItem="{Binding SelectedSampleRate}"
                        HorizontalAlignment="Stretch">
                <ComboBox.ItemTemplate>
                  <DataTemplate>
                    <TextBlock Text="{Binding Converter={StaticResource SampleRateConverter}}" />
                  </DataTemplate>
                </ComboBox.ItemTemplate>
              </ComboBox>

              <TextBlock Grid.Row="1" Grid.Column="0" Text="采样点:" VerticalAlignment="Center" Margin="0,0,10,0" />
              <TextBox Grid.Row="1" Grid.Column="1" Text="{Binding PointCount}" HorizontalAlignment="Stretch" />
            </Grid>

            <Border Height="1" Background="{DynamicResource SurfaceBorderBrush}" />

            <ItemsControl ItemsSource="{Binding ChannelProperties}">
              <ItemsControl.ItemsPanel>
                <ItemsPanelTemplate>
                  <StackPanel Spacing="8" />
                </ItemsPanelTemplate>
              </ItemsControl.ItemsPanel>
              <ItemsControl.ItemTemplate>
                <DataTemplate>
                  <Grid ColumnDefinitions="Auto,Auto,*">
                    <TextBlock Grid.Column="0"
                               Text="{Binding Id, StringFormat=ch{0}:}"
                               FontWeight="SemiBold"
                               MinWidth="38"
                               VerticalAlignment="Center" />
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                      <RadioButton Content="DC"
                                   IsChecked="{Binding SelectedCoupling, Converter={StaticResource EnumConverter}, ConverterParameter={x:Static brcsdk:CouplingMode.DC}}" />
                      <RadioButton Content="AC"
                                   IsChecked="{Binding SelectedCoupling, Converter={StaticResource EnumConverter}, ConverterParameter={x:Static brcsdk:CouplingMode.AC}}" />
                    </StackPanel>
                    <ComboBox Grid.Column="2"
                              ItemsSource="{Binding DataContext.Device.ModuleInfo.CurrentOptions, ElementName=Root}"
                              SelectedItem="{Binding SelectedCurrent}"
                              Margin="10,0,0,0"
                              HorizontalAlignment="Stretch">
                      <ComboBox.ItemTemplate>
                        <DataTemplate>
                          <TextBlock Text="{Binding Converter={StaticResource CurrentConverter}}" />
                        </DataTemplate>
                      </ComboBox.ItemTemplate>
                    </ComboBox>
                  </Grid>
                </DataTemplate>
              </ItemsControl.ItemTemplate>
            </ItemsControl>
          </StackPanel>
        </GroupBox>

        <Grid ColumnDefinitions="*,*" ColumnSpacing="8">
          <Button Grid.Column="0"
                  Classes="primary"
                  Command="{Binding StartCommand}"
                  IsEnabled="{Binding !Started}"
                  Content="开始"
                  HorizontalAlignment="Stretch" />
          <Button Grid.Column="1"
                  Command="{Binding StopCommand}"
                  IsEnabled="{Binding Started}"
                  Content="停止"
                  HorizontalAlignment="Stretch" />
        </Grid>
      </StackPanel>
    </ScrollViewer>
  </Grid>
</Window>
